# ArbitrageX Supreme V3.0 - Multi-Relay Client
# Configuración para desarrollo local

# ============================================================================
# APLICACIÓN
# ============================================================================
NODE_ENV=development
PORT=3004
HOST=0.0.0.0
LOG_LEVEL=debug

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6383
REDIS_PASSWORD=
REDIS_DB=3

# ============================================================================
# FAILOVER & CIRCUIT BREAKER CONFIGURATION
# ============================================================================
FAILOVER_STRATEGY=priority_based
MAX_CONSECUTIVE_FAILURES=3
FAILURE_BACKOFF_SECONDS=60
HEALTH_CHECK_INTERVAL=30
CIRCUIT_BREAKER_THRESHOLD=0.1
RECOVERY_TIME_SECONDS=300

# ============================================================================
# REAL-ONLY POLICY - RPC URLs REALES (OBLIGATORIO)
# ============================================================================
# CRÍTICO: Solo RPCs de mainnet reales, NO testnets ni mocks

# Ethereum Mainnet (Chain ID: 1) - OBLIGATORIO para Flashbots
RPC_URL_1=https://eth-mainnet.alchemyapi.io/v2/YOUR_ALCHEMY_KEY_HERE
# Alternativa: https://mainnet.infura.io/v3/YOUR_INFURA_KEY_HERE

# Polygon Mainnet (Chain ID: 137)
RPC_URL_137=https://polygon-mainnet.alchemyapi.io/v2/YOUR_ALCHEMY_KEY_HERE

# Arbitrum One (Chain ID: 42161)
RPC_URL_42161=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# Optimism (Chain ID: 10)  
RPC_URL_10=https://opt-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# Binance Smart Chain (Chain ID: 56)
RPC_URL_56=https://bsc-dataseed1.binance.org/

# Base (Chain ID: 8453)
RPC_URL_8453=https://mainnet.base.org

# ============================================================================
# RELAY API KEYS & AUTHENTICATION
# ============================================================================

# Flashbots Authentication (Ethereum Mainnet)
# REQUIRED: Private key para firmar bundles Flashbots
FLASHBOTS_SIGNING_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# bloXroute API Key  
# REQUIRED para bloXroute Max Profit
BLOXROUTE_API_KEY=your_bloxroute_api_key_here
BLOXROUTE_AUTH_HEADER=your_bloxroute_auth_header_here

# Eden Network API Key
# Opcional: Eden funciona sin API key pero con limits
EDEN_API_KEY=your_eden_api_key_here

# Beaver Build & Titan Builder
# Generalmente no requieren API keys para bundles básicos
BEAVER_ENDPOINT=https://rpc.beaverbuild.org
TITAN_ENDPOINT=https://rpc.titanbuilder.xyz

# ============================================================================
# EXECUTION WALLET
# ============================================================================
# CRITICAL: Wallet privada para firmar transacciones de arbitraje
# NUNCA usar wallet de producción en desarrollo
EXECUTION_PRIVATE_KEY=0xabcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890

# ============================================================================
# MEV CONFIGURATION
# ============================================================================
# MEV Protection settings
MEV_PROTECTION=true
PRIVATE_MEMPOOL_ONLY=true
BUNDLE_TIMEOUT_DEFAULT=30
MIN_RELAY_COUNT=2
MAX_RELAY_COUNT=5

# Bundle submission settings
BUNDLE_MAX_SIZE_MB=50
BUNDLE_MAX_TRANSACTIONS=50
BUNDLE_RETRY_ATTEMPTS=2

# Gas settings
MAX_GAS_PRICE_GWEI=500
MAX_PRIORITY_FEE_GWEI=10
GAS_ESTIMATION_BUFFER=1.2

# ============================================================================
# RATE LIMITING
# ============================================================================
# Más permisivo para operaciones MEV
RATE_LIMIT_MAX=500
RATE_LIMIT_WINDOW=60000

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_HOST=localhost:3004

# CORS Origins (separado por comas)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ============================================================================
# MONITORING & METRICS
# ============================================================================
# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PREFIX=relays_client_dev_

# Health check intervals (segundos)
HEALTH_CHECK_INTERVAL=30
RELAY_HEALTH_CHECK_INTERVAL=30

# Tracking configuration
TRACK_INCLUSION=true
MAX_TRACKING_BLOCKS=10
TRACKING_INTERVAL_SECONDS=12
AUTO_CLEANUP_HOURS=24

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
LOG_FILE_PATH=/app/logs/relays-client-dev.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# ============================================================================
# DEVELOPMENT TOOLS
# ============================================================================
# Hot reload
HOT_RELOAD_ENABLED=true

# Mock relay server (para testing sin APIs reales)
USE_MOCK_RELAYS=false
MOCK_RELAY_ENDPOINT=http://mock-relay-server:3000

# Debug mode
DEBUG_MODE=true
DEBUG_BUNDLE_CONTENT=true

# Swagger UI
SWAGGER_ENABLED=true

# ============================================================================
# EXTERNAL API KEYS
# ============================================================================
# Alchemy (recomendado para múltiples chains)
ALCHEMY_API_KEY_MAINNET=your_alchemy_mainnet_key_here
ALCHEMY_API_KEY_POLYGON=your_alchemy_polygon_key_here
ALCHEMY_API_KEY_ARBITRUM=your_alchemy_arbitrum_key_here
ALCHEMY_API_KEY_OPTIMISM=your_alchemy_optimism_key_here
ALCHEMY_API_KEY_BASE=your_alchemy_base_key_here

# Infura (alternativa)
INFURA_PROJECT_ID=your_infura_project_id_here
INFURA_PROJECT_SECRET=your_infura_project_secret_here

# ============================================================================
# RELAY ENDPOINTS (DEVELOPMENT)
# ============================================================================
# Endpoints reales para desarrollo (usar con cuidado)
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
BLOXROUTE_RELAY_URL=https://mev.api.blxrbdn.com  
EDEN_RELAY_URL=https://api.edennetwork.io
BEAVER_RELAY_URL=https://rpc.beaverbuild.org
TITAN_RELAY_URL=https://rpc.titanbuilder.xyz

# ============================================================================
# SECURITY WARNINGS & NOTAS
# ============================================================================
# 1. NUNCA commitear este archivo con claves reales
# 2. Usar solo RPCs de mainnet (Real-Only Policy)
# 3. Private keys de desarrollo solamente
# 4. Para producción: usar secrets manager
# 5. Flashbots requiere signing key válida
# 6. bloXroute requiere API key válida para submission
# 7. Testear siempre con wallets de desarrollo
# 8. Monitorear logs para detectar problemas de relay

# ============================================================================
# QUICK START CHECKLIST
# ============================================================================
# □ Configurar RPC_URL_1 (Ethereum mainnet) - OBLIGATORIO
# □ Configurar FLASHBOTS_SIGNING_KEY - OBLIGATORIO  
# □ Configurar EXECUTION_PRIVATE_KEY (dev wallet) - OBLIGATORIO
# □ Configurar BLOXROUTE_API_KEY (si se usa bloXroute)
# □ Verificar que Redis esté corriendo en puerto 6383
# □ Copiar este archivo a .env.development
# □ Ejecutar: docker-compose -f docker-compose.dev.yml up -d