# =============================================================================
# ArbitrageX Supreme V3.0 - Relays Client Environment Configuration
# =============================================================================

# Service Configuration
NODE_ENV=development
RELAYS_CLIENT_NAME=relays-client
RELAYS_CLIENT_VERSION=3.0.0
RELAYS_CLIENT_PORT=3004
RELAYS_CLIENT_HOST=0.0.0.0
LOG_LEVEL=info

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=relays:
REDIS_TTL=3600

# Ethereum Network Configuration
ETHEREUM_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/YOUR-API-KEY
ETHEREUM_CHAIN_ID=1
GAS_LIMIT_MULTIPLIER=1.2
GAS_PRICE_MULTIPLIER=1.1
MAX_GAS_PRICE_GWEI=500
BLOCK_CONFIRMATION_THRESHOLD=1

# Flashbots Configuration
FLASHBOTS_ENABLED=true
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
FLASHBOTS_SIGNING_KEY=YOUR-PRIVATE-KEY-HEX
FLASHBOTS_REPUTATION_KEY=YOUR-REPUTATION-KEY-HEX
FLASHBOTS_MAX_BUNDLE_SIZE=10
FLASHBOTS_TIMEOUT=30000
FLASHBOTS_RETRY_ATTEMPTS=3
FLASHBOTS_MIN_BID_INCREMENT=1000000000
FLASHBOTS_SIMULATION_ENABLED=true

# bloXroute Configuration
BLOXROUTE_ENABLED=true
BLOXROUTE_API_URL=https://mev.api.blxrbdn.com
BLOXROUTE_AUTH_HEADER=YOUR-AUTH-HEADER
BLOXROUTE_MAX_BUNDLE_SIZE=15
BLOXROUTE_TIMEOUT=25000
BLOXROUTE_RETRY_ATTEMPTS=2
BLOXROUTE_PROFIT_THRESHOLD=10000000000000000

# Eden Network Configuration
EDEN_ENABLED=true
EDEN_RPC_URL=https://api.edennetwork.io/v1/rpc
EDEN_SLOT_URL=https://api.edennetwork.io/v1/slots
EDEN_API_KEY=YOUR-EDEN-API-KEY
EDEN_MAX_BUNDLE_SIZE=8
EDEN_TIMEOUT=20000
EDEN_RETRY_ATTEMPTS=2
EDEN_STAKING_TOKEN=EDEN
EDEN_MIN_STAKE_AMOUNT=100000000000000000000

# Manifold Finance Configuration (Optional)
MANIFOLD_ENABLED=false
MANIFOLD_API_URL=https://api.manifoldfinance.com/v1
MANIFOLD_API_KEY=YOUR-MANIFOLD-API-KEY
MANIFOLD_MAX_BUNDLE_SIZE=12
MANIFOLD_TIMEOUT=22000
MANIFOLD_RETRY_ATTEMPTS=2

# Bundle Management Configuration
MAX_CONCURRENT_BUNDLES=100
BUNDLE_TTL_SECONDS=300
AUTO_RESUBMISSION_ENABLED=true
MAX_RESUBMISSION_ATTEMPTS=5
PROFIT_THRESHOLD_USD=50
GAS_PRICE_BUFFER_PERCENTAGE=10

# Real-Only Policy Configuration
REAL_ONLY_ENABLED=true
REAL_ONLY_ALLOWED_TEST_CHAINS=31337,1337
REAL_ONLY_BLOCK_SIMULATION=false
REAL_ONLY_REQUIRE_SIGNED=true
REAL_ONLY_VALIDATE_ENDPOINTS=true
REAL_ONLY_ENFORCE_MAINNET=true

# Monitoring Configuration
MONITORING_ENABLED=true
PROMETHEUS_PORT=9094
HEALTH_CHECK_INTERVAL=30000
BUNDLE_TRACKING_ENABLED=true
RELAY_PERFORMANCE_TRACKING=true
ALERT_FAILURE_RATE=0.5
ALERT_LOW_INCLUSION_RATE=0.1

# Security Configuration
MAX_BUNDLE_VALUE_ETH=1000
REQUIRE_BUNDLE_SIMULATION=true
SIGNING_KEY_ROTATION_ENABLED=false
RATE_LIMIT_PER_MINUTE=100
WHITELIST_ENABLED=false
ALLOWED_CONTRACT_ADDRESSES=