# ArbitrageX Supreme V3.0 - Recon Service Environment Configuration
# Real-Only Policy - All configurations for production deployment

# Server Configuration
NODE_ENV=production
RECON_PORT=8001
RECON_HOST=0.0.0.0
RECON_LOG_LEVEL=info

# Database Configuration (PostgreSQL)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=arbitragex_recon
POSTGRES_USER=arbitragex
POSTGRES_PASSWORD=secure_password_change_in_production
POSTGRES_MAX_CONNECTIONS=20

# Redis Configuration (for caching and event streaming)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_in_production

# Reconciliation Configuration
RECON_BATCH_SIZE=100
RECON_MAX_INVESTIGATIONS=10
RECON_INVESTIGATION_TIMEOUT=300000

# Observability Configuration
RECON_METRICS_ENABLED=true
RECON_TRACING_ENABLED=false

# Security Configuration
JWT_SECRET=jwt_secret_change_in_production
API_KEY_HEADER=X-API-Key

# External Service Integration
SEARCHER_RS_URL=http://searcher-rs:8000
SELECTOR_API_URL=http://selector-api:8002
SIM_CTL_URL=http://sim-ctl:8003
RELAYS_CLIENT_URL=http://relays-client:8004

# Network Configuration (for multi-chain support)
ETH_RPC_URL=http://geth:8545
POLYGON_RPC_URL=https://polygon-rpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# MEV Configuration
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
BUILDER_API_URL=https://builder-api.flashbots.net

# Monitoring and Alerting
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
LOKI_URL=http://loki:3100

# Alert Configuration
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# Performance Tuning
UV_THREADPOOL_SIZE=16
NODE_OPTIONS="--max-old-space-size=2048"

# Development Configuration (only for local development)
# DEV_MODE=false
# ENABLE_CORS=false
# RATE_LIMIT_ENABLED=true