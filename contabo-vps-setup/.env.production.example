# ================================
# ArbitrageX Supreme V3.0 - Contabo VPS Production Environment
# Configuración de producción real (no pruebas)
# ================================

# ================================
# Configuración del Servidor Contabo
# ================================
CONTABO_HOST=your-contabo-server.com
CONTABO_USER=root
CONTABO_PORT=22
SERVER_REGION=europe
DOMAIN_NAME=arbitragex.your-domain.com

# ================================
# Base de Datos y Cache
# ================================
POSTGRES_PASSWORD=ultra-secure-postgres-password-change-me
POSTGRES_DB=arbitragex_prod
POSTGRES_USER=arbitragex
REDIS_PASSWORD=ultra-secure-redis-password-change-me

# ================================
# Monitoreo y Observability
# ================================
GRAFANA_PASSWORD=ultra-secure-grafana-password-change-me
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ================================
# Blockchain RPCs (REAL ONLY - NO MOCKS)
# ================================
# Ethereum Mainnet (Geth local + fallbacks)
MAINNET_RPC_URL=http://geth:8545
MAINNET_RPC_FALLBACK_1=https://eth-mainnet.g.alchemy.com/v2/YOUR-ALCHEMY-KEY
MAINNET_RPC_FALLBACK_2=https://mainnet.infura.io/v3/YOUR-INFURA-KEY
MAINNET_RPC_FALLBACK_3=https://rpc.ankr.com/eth

# Layer 2s y Sidechains
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR-ALCHEMY-KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR-ALCHEMY-KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR-ALCHEMY-KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR-ALCHEMY-KEY

# Otras chains
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
FANTOM_RPC_URL=https://rpc.ftm.tools/
GNOSIS_RPC_URL=https://rpc.gnosischain.com/

# ================================
# Multi-Relay Configuration (Private Mode)
# ================================
# Flashbots
FLASHBOTS_URL=https://relay.flashbots.net
FLASHBOTS_SIGNATURE_KEY=your-flashbots-signature-key

# bloXroute
BLOXROUTE_URL=https://mev.api.blxrbdn.com
BLOXROUTE_AUTH_HEADER=your-bloxroute-auth-token

# Eden Network
EDEN_URL=https://api.edennetwork.io/v1
EDEN_API_KEY=your-eden-api-key

# Relay Configuration
RELAY_TIMEOUT_SECONDS=5
RELAY_MAX_RETRIES=3
RELAY_BACKOFF_MULTIPLIER=2
PRIVATE_MEMPOOL_ONLY=true

# ================================
# MEV y Private Pool Configuration
# ================================
# Target Block Configuration
TARGET_BLOCK_OFFSET=1
TTL_BLOCKS=5
MAX_BUNDLE_SIZE=5

# Gas Configuration
GAS_PRICE_MULTIPLIER=1.1
MAX_GAS_PRICE_GWEI=300
PRIORITY_FEE_MULTIPLIER=1.2
BASE_FEE_MULTIPLIER=1.1

# ================================
# Estrategias Activas (Core: A,C,D,F)
# ================================
# Strategy A - DEX Arbitrage
STRATEGY_A_ENABLED=true
STRATEGY_A_MIN_PROFIT_USD=50
STRATEGY_A_MAX_GAS_GWEI=150
STRATEGY_A_SLIPPAGE_TOLERANCE=0.005

# Strategy C - Cross-chain Arbitrage  
STRATEGY_C_ENABLED=true
STRATEGY_C_MIN_PROFIT_USD=100
STRATEGY_C_BRIDGE_TIMEOUT_MINUTES=30
STRATEGY_C_SUPPORTED_CHAINS=ethereum,arbitrum,polygon,optimism

# Strategy D - Delta-neutral
STRATEGY_D_ENABLED=true
STRATEGY_D_MIN_SPREAD_BPS=30
STRATEGY_D_MAX_POSITION_USD=50000
STRATEGY_D_REBALANCE_THRESHOLD=0.02

# Strategy F - Flash Loan Arbitrage
STRATEGY_F_ENABLED=true
STRATEGY_F_MIN_PROFIT_USD=25
STRATEGY_F_FLASH_LOAN_FEE_BPS=9
STRATEGY_F_MAX_LOAN_USD=1000000

# ================================
# Selectors Configuration
# ================================
# Chain Selector
CHAIN_SELECTOR_MIN_TVL_USD=10000000
CHAIN_SELECTOR_MAX_CHAINS=20
CHAIN_SELECTOR_LATENCY_THRESHOLD_MS=500
CHAIN_SELECTOR_RELIABILITY_THRESHOLD=0.99

# DEX Selector  
DEX_SELECTOR_MIN_LIQUIDITY_USD=100000
DEX_SELECTOR_MIN_VOLUME_24H_USD=1000000
DEX_SELECTOR_TWAP_STABLE_THRESHOLD=0.02
DEX_SELECTOR_FEE_TIER_PREFERENCE=low,medium,high

# Lending Selector (Aave v3 prioritized)
LENDING_SELECTOR_PROTOCOLS=aave_v3,compound_v3,morpho
LENDING_SELECTOR_MIN_RESERVES_USD=5000000
LENDING_SELECTOR_MAX_UTILIZATION=0.85
LENDING_SELECTOR_MAX_LOAN_FEE_BPS=50

# Token Filter (Positive List)
TOKEN_FILTER_MIN_MARKET_CAP_USD=10000000
TOKEN_FILTER_MIN_LIQUIDITY_USD=1000000
TOKEN_FILTER_MIN_DAILY_VOLUME_USD=5000000
TOKEN_FILTER_MAX_VOLATILITY_24H=0.20
TOKEN_FILTER_REQUIRE_COINGECKO=true

# ================================
# Anvil-Real Simulation Configuration
# ================================
SIM_CTL_FORK_MODE=ephemeral
SIM_CTL_NO_MINING=true
SIM_CTL_BLOCK_TIME=12
SIM_CTL_GAS_LIMIT=30000000
SIM_CTL_BASE_FEE=20000000000
SIM_CTL_ACCOUNTS=10
SIM_CTL_BALANCE=10000

# Simulation Validation
SIM_VALIDATION_ENABLED=true
SIM_ROI_THRESHOLD_BPS=100
SIM_TWAP_DEVIATION_THRESHOLD=0.05
SIM_HASH_ALGORITHM=keccak256

# ================================
# API Keys Externas (REAL DATA ONLY)
# ================================
# CoinGecko Pro (for market data)
COINGECKO_PRO_API_KEY=your-coingecko-pro-api-key

# Moralis (for blockchain data)
MORALIS_API_KEY=your-moralis-api-key

# The Graph (for DeFi data)
THEGRAPH_API_KEY=your-thegraph-api-key

# Etherscan family (for contract verification)
ETHERSCAN_API_KEY=your-etherscan-api-key
ARBISCAN_API_KEY=your-arbiscan-api-key
POLYGONSCAN_API_KEY=your-polygonscan-api-key
OPTIMISM_API_KEY=your-optimism-etherscan-api-key
BSCSCAN_API_KEY=your-bscscan-api-key

# DeFiLlama (for TVL data)
DEFILLAMA_API_KEY=your-defillama-api-key

# 1inch (for DEX aggregation data)
ONEINCH_API_KEY=your-1inch-api-key

# ================================
# Reconciliation Configuration
# ================================
RECON_EPSILON_THRESHOLD=0.01
RECON_SIM_EXEC_MAX_DEVIATION=0.05
RECON_PNL_ANALYSIS_ENABLED=true
RECON_CAUSE_ANALYSIS_ENABLED=true
RECON_ALERT_THRESHOLD=0.10

# ================================
# Performance y Rate Limiting
# ================================
# Latency Targets
TARGET_API_LATENCY_MS=100
TARGET_EXECUTION_LATENCY_MS=200
TARGET_SIMULATION_LATENCY_MS=50

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_BURST_SIZE=200
RATE_LIMIT_WINDOW_SECONDS=60

# Connection Pools
DATABASE_MAX_CONNECTIONS=50
REDIS_MAX_CONNECTIONS=20
RPC_MAX_CONNECTIONS=100

# ================================
# Logging Configuration
# ================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_ROTATION_SIZE=100MB
LOG_RETENTION_DAYS=30

# Structured Logging
ENABLE_STRUCTURED_LOGS=true
ENABLE_REQUEST_LOGS=true
ENABLE_ERROR_TRACKING=true
ENABLE_PERFORMANCE_LOGS=true

# ================================
# Security Configuration
# ================================
# API Security
API_RATE_LIMIT_ENABLED=true
API_AUTH_REQUIRED=true
API_CORS_ORIGINS=https://your-frontend-domain.com

# Private Key Management (use secure key management)
EXECUTION_PRIVATE_KEY_ID=your-key-id-in-secure-vault
SIGNING_PRIVATE_KEY_ID=your-signing-key-id

# Network Security
FIREWALL_ENABLED=true
SSH_KEY_ONLY=true
FAIL2BAN_ENABLED=true

# ================================
# Backup Configuration
# ================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=/opt/backups/arbitragex
BACKUP_ENCRYPTION_ENABLED=true

# ================================
# Alerting Configuration
# ================================
ALERTS_ENABLED=true
ALERT_WEBHOOK_URL=https://your-webhook-url.com/alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/your-webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook

# Critical Alerts
ALERT_LATENCY_THRESHOLD_MS=500
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_PNL_DEVIATION_THRESHOLD=0.15
ALERT_RELAY_FAILURE_THRESHOLD=0.20

# ================================
# Cron Jobs Configuration
# ================================
CRON_HOURLY_UPDATE_ENABLED=true
CRON_CHAINS_SYNC_SCHEDULE=0 * * * *
CRON_DEX_SYNC_SCHEDULE=15 * * * *  
CRON_LENDING_SYNC_SCHEDULE=30 * * * *
CRON_ASSETS_SYNC_SCHEDULE=45 * * * *

# Data Validation
CRON_VALIDATE_DATA=true
CRON_CLEANUP_OLD_DATA=true
CRON_CLEANUP_RETENTION_HOURS=168

# ================================
# Development y Testing (Disable in Production)
# ================================
DEBUG_MODE=false
ENABLE_DEV_ENDPOINTS=false
MOCK_DATA_ENABLED=false
SIMULATION_ONLY_MODE=false
ENABLE_TEST_STRATEGIES=false