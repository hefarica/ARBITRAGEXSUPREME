# =============================================================================
# ArbitrageX Supreme V3.0 - Sim-Ctl Environment Configuration
# =============================================================================

# Service Configuration
NODE_ENV=development
SIM_CTL_NAME=sim-ctl
SIM_CTL_VERSION=3.0.0
SIM_CTL_PORT=3003
SIM_CTL_HOST=0.0.0.0
LOG_LEVEL=info

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=simctl:
REDIS_TTL=3600

# Anvil Configuration
ANVIL_BINARY_PATH=/usr/local/bin/anvil
ANVIL_DATA_DIR=/tmp/anvil-instances
ANVIL_MAX_INSTANCES=10
ANVIL_INSTANCE_TIMEOUT=3600
ANVIL_HEARTBEAT_INTERVAL=10000
ANVIL_CLEANUP_INTERVAL=60000
ANVIL_PORT_START=8545
ANVIL_PORT_END=8595
ANVIL_DEFAULT_CHAIN_ID=31337

# Simulation Configuration
SIM_MAX_EXECUTION_TIME=5000
SIM_DEFAULT_GAS_LIMIT=30000000
SIM_DEFAULT_GAS_PRICE=20000000000
SIM_MAX_SLIPPAGE=0.05
SIM_PROFIT_THRESHOLD=10

# Blockchain RPC Configuration
ETHEREUM_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/YOUR-API-KEY
ETHEREUM_CHAIN_ID=1
ETHEREUM_NATIVE_TOKEN=ETH
ETHEREUM_BLOCK_TIME=12

ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR-API-KEY
ARBITRUM_CHAIN_ID=42161
ARBITRUM_NATIVE_TOKEN=ETH
ARBITRUM_BLOCK_TIME=0.25

POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR-API-KEY
POLYGON_CHAIN_ID=137
POLYGON_NATIVE_TOKEN=MATIC
POLYGON_BLOCK_TIME=2

BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_CHAIN_ID=56
BSC_NATIVE_TOKEN=BNB
BSC_BLOCK_TIME=3

# Real-Only Policy Configuration
REAL_ONLY_ENABLED=true
REAL_ONLY_ALLOWED_TEST_CHAINS=31337,1337
REAL_ONLY_BLOCK_MOCKS=true
REAL_ONLY_REQUIRE_REAL_RPCS=true
REAL_ONLY_VALIDATE_CHAIN_DATA=true

# Monitoring Configuration
MONITORING_ENABLED=true
PROMETHEUS_PORT=9093
HEALTH_CHECK_INTERVAL=30000
ALERT_FAILURE_COUNT=3