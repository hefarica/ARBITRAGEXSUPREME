# ================================
# Configuración de Arbitraje
# ================================
# Latencia máxima objetivo (milisegundos)
MAX_LATENCY_MS=200

# Políticas estrictas Real-Only
REAL_ONLY_MODE=true
ALLOW_MOCKS=false
REQUIRE_REAL_PRICES=true

# Estrategias habilitadas (13 estrategias matemáticamente validadas)
ENABLED_STRATEGIES='[
  "dex_arbitrage",
  "triangular_arbitrage", 
  "cross_chain_arbitrage",
  "statistical_arbitrage",
  "flash_loan_arbitrage",
  "liquidity_arbitrage",
  "yield_farming_arbitrage",
  "sandwich_attacks",
  "mev_arbitrage",
  "protocol_arbitrage",
  "governance_arbitrage",
  "liquidation_arbitrage",
  "funding_rate_arbitrage"
]'

# ================================
# Configuración de Seguridad
# ================================
# Anti-rugpull protection
ENABLE_RUGPULL_PROTECTION=true
MIN_LIQUIDITY_USD=50000
MIN_TOKEN_AGE_DAYS=7
BLACKLIST_KNOWN_RUGS=true

# Configuración de riesgo
MAX_POSITION_SIZE_USD=100000
MAX_SLIPPAGE_BPS=50
REQUIRE_MULTI_DEX_CONFIRMATION=true

# ================================
# APIs Externas (Real Data Sources)
# ================================
# CoinGecko Pro API
COINGECKO_API_KEY=your-coingecko-pro-api-key

# Moralis API
MORALIS_API_KEY=your-moralis-api-key

# The Graph API
THEGRAPH_API_KEY=your-thegraph-api-key

# Etherscan APIs
ETHERSCAN_API_KEY=your-etherscan-api-key
ARBISCAN_API_KEY=your-arbiscan-api-key
POLYGONSCAN_API_KEY=your-polygonscan-api-key
OPTIMISM_API_KEY=your-optimism-etherscan-api-key
BSCSCAN_API_KEY=your-bscscan-api-key

# ================================
# Configuración de Performance
# ================================
# Workers y concurrencia
WORKER_THREADS=8
MAX_CONCURRENT_REQUESTS=100
PRICE_UPDATE_INTERVAL_MS=100
ARBITRAGE_CHECK_INTERVAL_MS=50

# Cache y Redis
REDIS_MAX_MEMORY=1gb
REDIS_EVICTION_POLICY=allkeys-lru
CACHE_TTL_SECONDS=60

# ================================
# Logging y Monitoreo
# ================================
RUST_LOG=info
LOG_LEVEL=info
ENABLE_METRICS=true
METRICS_INTERVAL_SECONDS=30

# ================================
# Configuración de Red
# ================================
API_HOST=0.0.0.0
API_PORT=8080
WEBSOCKET_PORT=8081
METRICS_PORT=9090

# ================================
# Configuración SSL/TLS (Opcional)
# ================================
# Descomentar si usas SSL
# SSL_CERT_PATH=/etc/ssl/certs/arbitragex.crt
# SSL_KEY_PATH=/etc/ssl/private/arbitragex.key
# FORCE_HTTPS=true