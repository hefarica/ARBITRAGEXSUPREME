# ================================
# ArbitrageX Supreme V3.0 - Production Environment
# Configuración para Contabo VPS
# ================================

# ================================
# Configuración del Servidor
# ================================
CONTABO_HOST=your-server.contabo.host
CONTABO_USER=root
CONTABO_PORT=22
DOMAIN_NAME=your-domain.com

# ================================
# Base de Datos PostgreSQL
# ================================
POSTGRES_PASSWORD=your-ultra-secure-postgres-password
POSTGRES_DB=arbitragex_prod
POSTGRES_USER=arbitragex

# ================================
# Monitoreo y Métricas
# ================================
GRAFANA_PASSWORD=your-ultra-secure-grafana-password

# ================================
# Blockchain RPCs (Real-Only Policy)
# ================================
# CRÍTICO: Estos deben ser RPCs reales, no mocks
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your-api-key
