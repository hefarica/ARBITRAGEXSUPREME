# ArbitrageX Supreme V3.0 - Simulation Controller
# Configuración para desarrollo local

# ============================================================================
# APLICACIÓN
# ============================================================================
NODE_ENV=development
PORT=3002
HOST=0.0.0.0
LOG_LEVEL=debug

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=
REDIS_DB=2

# ============================================================================
# REAL-ONLY POLICY - RPC URLs REALES
# ============================================================================
# IMPORTANTE: Configurar RPCs reales, no usar endpoints de prueba

# Ethereum Mainnet (Chain ID: 1)
RPC_URL_1=https://eth-mainnet.alchemyapi.io/v2/YOUR_ALCHEMY_KEY_HERE
# Alternativa: https://mainnet.infura.io/v3/YOUR_INFURA_KEY_HERE

# Polygon Mainnet (Chain ID: 137) 
RPC_URL_137=https://polygon-mainnet.alchemyapi.io/v2/YOUR_ALCHEMY_KEY_HERE
# Alternativa: https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY_HERE

# Arbitrum One (Chain ID: 42161)
RPC_URL_42161=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE
# Alternativa: https://arbitrum-mainnet.infura.io/v3/YOUR_INFURA_KEY_HERE

# Optimism (Chain ID: 10)
RPC_URL_10=https://opt-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE
# Alternativa: https://optimism-mainnet.infura.io/v3/YOUR_INFURA_KEY_HERE

# Binance Smart Chain (Chain ID: 56)
RPC_URL_56=https://bsc-dataseed1.binance.org/
# Alternativa: https://rpc.ankr.com/bsc

# Avalanche C-Chain (Chain ID: 43114)
RPC_URL_43114=https://api.avax.network/ext/bc/C/rpc
# Alternativa: https://rpc.ankr.com/avalanche

# Fantom (Chain ID: 250)
RPC_URL_250=https://rpc.ftm.tools/
# Alternativa: https://rpc.ankr.com/fantom

# Base (Chain ID: 8453)
RPC_URL_8453=https://mainnet.base.org
# Alternativa: https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# ============================================================================
# API KEYS PARA SERVICIOS EXTERNOS
# ============================================================================
# Alchemy (recomendado para múltiples chains)
ALCHEMY_API_KEY_MAINNET=your_alchemy_mainnet_key_here
ALCHEMY_API_KEY_POLYGON=your_alchemy_polygon_key_here  
ALCHEMY_API_KEY_ARBITRUM=your_alchemy_arbitrum_key_here
ALCHEMY_API_KEY_OPTIMISM=your_alchemy_optimism_key_here

# Infura (alternativa)
INFURA_PROJECT_ID=your_infura_project_id_here
INFURA_PROJECT_SECRET=your_infura_project_secret_here

# ============================================================================
# CONFIGURACIÓN DE ANVIL INSTANCES
# ============================================================================
# Estrategia A - DEX Arbitrage (puertos 8545-8554)
STRATEGY_A_MIN_INSTANCES=2
STRATEGY_A_MAX_INSTANCES=4
STRATEGY_A_DEFAULT_CHAIN=1

# Estrategia C - Cross-Chain Arbitrage (puertos 8555-8564)  
STRATEGY_C_MIN_INSTANCES=2
STRATEGY_C_MAX_INSTANCES=5
STRATEGY_C_DEFAULT_CHAIN=137

# Estrategia D - Lending Arbitrage (puertos 8565-8574)
STRATEGY_D_MIN_INSTANCES=2
STRATEGY_D_MAX_INSTANCES=3
STRATEGY_D_DEFAULT_CHAIN=42161

# Estrategia F - Flash Loan Arbitrage (puertos 8575-8584)
STRATEGY_F_MIN_INSTANCES=2
STRATEGY_F_MAX_INSTANCES=4
STRATEGY_F_DEFAULT_CHAIN=1

# ============================================================================
# CONFIGURACIÓN DE RATE LIMITING
# ============================================================================
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=60000

# ============================================================================
# CONFIGURACIÓN DE API
# ============================================================================
API_HOST=localhost:3002

# CORS Origins (separado por comas)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# ============================================================================
# CONFIGURACIÓN DE MONITOREO
# ============================================================================
# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PREFIX=sim_ctl_dev_

# Health check intervals (segundos)
HEALTH_CHECK_INTERVAL=30
INSTANCE_HEALTH_CHECK_INTERVAL=60

# ============================================================================
# CONFIGURACIÓN DE LOGGING
# ============================================================================
# Niveles: error, warn, info, debug
LOG_LEVEL=debug
LOG_FILE_PATH=/app/logs/sim-ctl-dev.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# ============================================================================
# CONFIGURACIÓN DE SIMULACIONES
# ============================================================================
# Timeouts por defecto (segundos)
DEFAULT_SIMULATION_TIMEOUT=60
MAX_SIMULATION_TIMEOUT=300

# Gas settings para simulaciones
DEFAULT_GAS_LIMIT=30000000
DEFAULT_GAS_PRICE=1000000000
DEFAULT_ACCOUNT_BALANCE=10000

# ============================================================================
# CONFIGURACIÓN DE DESARROLLO
# ============================================================================
# Hot reload
HOT_RELOAD_ENABLED=true

# Debug mode
DEBUG_MODE=true

# Swagger UI
SWAGGER_ENABLED=true

# Mock data para testing (solo desarrollo)
ENABLE_MOCK_DATA=false

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
# 1. NUNCA commitear este archivo con API keys reales
# 2. Copiar a .env.development y configurar valores reales  
# 3. Real-Only Policy: solo usar RPCs de mainnet reales
# 4. Para desarrollo local, usar docker-compose.dev.yml
# 5. Asegurar que todos los RPC_URL_* apunten a networks reales