# ArbitrageX Supreme V3.0 - Cron Service Environment Configuration
# Real-Only Policy - All configurations for production deployment

# Node Environment
NODE_ENV=production

# Server Configuration
CRON_PORT=8005
CRON_HOST=0.0.0.0
CRON_LOG_LEVEL=info
CRON_LOG_PATH=/var/log/arbitragex/cron.log

# Database Configuration (PostgreSQL)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=arbitragex_recon
POSTGRES_USER=arbitragex
POSTGRES_PASSWORD=secure_password_change_in_production
POSTGRES_MAX_CONNECTIONS=10

# Redis Configuration (for caching and coordination)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_in_production
REDIS_DB=0

# Blockchain Network Configuration
ENABLED_CHAINS=1,137,56,42161,10,8453,43114,250

# Ethereum Mainnet (Chain ID: 1)
ETH_RPC_URL=http://geth:8545
ETH_WS_URL=ws://geth:8546

# Polygon (Chain ID: 137)
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WS_URL=wss://polygon-rpc.com

# BSC (Chain ID: 56)
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_WS_URL=wss://bsc-ws-node.nariox.org:443

# Arbitrum One (Chain ID: 42161)
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_WS_URL=wss://arb1.arbitrum.io/ws

# Optimism (Chain ID: 10)
OPTIMISM_RPC_URL=https://mainnet.optimism.io
OPTIMISM_WS_URL=wss://mainnet.optimism.io/ws

# Base (Chain ID: 8453)
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=wss://mainnet.base.org/ws

# Avalanche (Chain ID: 43114)
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_WS_URL=wss://api.avax.network/ext/bc/C/ws

# Fantom (Chain ID: 250)
FANTOM_RPC_URL=https://rpc.ftm.tools
FANTOM_WS_URL=wss://rpc.ftm.tools/ws

# External API Keys and Configuration
COINGECKO_API_KEY=
DEXSCREENER_API_KEY=
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
BSCSCAN_API_KEY=
ARBISCAN_API_KEY=

# Data Source Rate Limits (requests per minute)
COINGECKO_RATE_LIMIT=50
DEXSCREENER_RATE_LIMIT=300
ETHERSCAN_RATE_LIMIT=200

# Job Configuration
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_MINUTES=30
JOB_RETRY_ATTEMPTS=3
JOB_RETRY_DELAY_SECONDS=60

# Token Price Update Configuration
PRICE_UPDATE_INTERVAL_MINUTES=2
PRICE_UPDATE_BATCH_SIZE=100
PRICE_CACHE_TTL_SECONDS=300

# Liquidity Pool Update Configuration
POOL_UPDATE_INTERVAL_MINUTES=5
POOL_UPDATE_BATCH_SIZE=50
POOL_MIN_LIQUIDITY_USD=10000

# Gas Price Update Configuration
GAS_UPDATE_INTERVAL_MINUTES=1
GAS_PRICE_CACHE_TTL_SECONDS=60

# MEV Opportunity Configuration
MEV_SCAN_INTERVAL_MINUTES=3
MEV_MIN_PROFIT_ETH=0.01
MEV_MAX_GAS_PRICE_GWEI=100

# Performance Monitoring
ENABLE_METRICS=true
METRICS_PORT=8005
HEALTH_CHECK_INTERVAL_SECONDS=30

# Data Retention Configuration
PRICE_DATA_RETENTION_DAYS=7
LOG_RETENTION_DAYS=30
EXECUTION_LOG_RETENTION_DAYS=30

# Alert Configuration
ALERT_ON_JOB_FAILURE=true
ALERT_ON_LONG_DURATION=true
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Performance Tuning
UV_THREADPOOL_SIZE=8
NODE_OPTIONS="--max-old-space-size=1024"

# Development Configuration (only for local development)
# DEV_MODE=false
# ENABLE_DEBUG_LOGS=false
# MOCK_EXTERNAL_APIS=false