{
  "dashboard": {
    "id": null,
    "title": "ArbitrageX Supreme V3.0 - Ultra-Low Latency E2E Monitoring",
    "tags": ["arbitragex", "latency", "trading", "rust", "ingenio-pichichi"],
    "style": "dark",
    "timezone": "UTC",
    "panels": [
      {
        "id": 1,
        "title": "🎯 Latency Budget Breakdown (Target: <100ms P95)",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(arbitragex_opportunity_scanner_processing_duration_bucket[1m]))",
            "legendFormat": "Scanner (≤15ms)",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(arbitragex_router_executor_routing_duration_bucket[1m]))",
            "legendFormat": "Routing (≤5ms)",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.95, rate(arbitragex_ml_inference_duration_bucket[1m]))",
            "legendFormat": "ML Inference (≤2ms)",
            "refId": "C"
          },
          {
            "expr": "histogram_quantile(0.95, rate(arbitragex_flashbots_submission_duration_bucket[1m]))",
            "legendFormat": "Flashbots Submit (≤10ms)",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "displayMode": "basic",
              "orientation": "horizontal"
            },
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 20}
              ]
            },
            "unit": "ms"
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto"
        },
        "pluginVersion": "10.0.0",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "⚡ Real-Time Latency Distribution (P50/P95/P99)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(arbitragex_total_execution_duration_bucket[1m]))",
            "legendFormat": "P50 Total Latency",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(arbitragex_total_execution_duration_bucket[1m]))",
            "legendFormat": "P95 Total Latency",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(arbitragex_total_execution_duration_bucket[1m]))",
            "legendFormat": "P99 Total Latency",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "barAlignment": 0,
              "lineWidth": 2,
              "fillOpacity": 20,
              "gradientMode": "opacity",
              "spanNulls": false,
              "insertNulls": false,
              "showPoints": "never",
              "pointSize": 5,
              "stacking": {"mode": "none", "group": "A"},
              "axisPlacement": "auto",
              "axisLabel": "",
              "axisColorMode": "text",
              "scaleDistribution": {"type": "linear"},
              "axisCenteredZero": false,
              "hideFrom": {"legend": false, "tooltip": false, "vis": false},
              "thresholdsStyle": {"mode": "line"}
            },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 100},
                {"color": "red", "value": 150}
              ]
            },
            "unit": "ms",
            "min": 0,
            "max": 200
          }
        },
        "options": {
          "tooltip": {"mode": "multi", "sort": "none"},
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "showLegend": true,
            "calcs": ["last", "max"]
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "🌍 Edge-to-Backend Latency by Region",
        "type": "heatmap",
        "targets": [
          {
            "expr": "rate(arbitragex_geo_router_backend_latency_bucket[5m])",
            "legendFormat": "{{region}} → {{backend_region}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {"legend": false, "tooltip": false, "vis": false},
              "scaleDistribution": {"type": "linear"}
            }
          }
        },
        "options": {
          "calculate": true,
          "cellGap": 2,
          "cellValues": {
            "decimals": 1
          },
          "color": {
            "exponent": 0.5,
            "fill": "dark-orange",
            "mode": "spectrum",
            "reverse": false,
            "scale": "exponential",
            "scheme": "Spectral",
            "steps": 128
          },
          "exemplars": {
            "color": "rgba(255,0,255,0.7)"
          },
          "filterValues": {
            "le": 1e-9
          },
          "legend": {
            "show": true
          },
          "rowsFrame": {
            "layout": "auto"
          },
          "tooltip": {
            "show": true,
            "yHistogram": false
          },
          "yAxis": {
            "axisPlacement": "left",
            "reverse": false,
            "unit": "ms"
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "🔥 Hot Path Performance Metrics",
        "type": "table",
        "targets": [
          {
            "expr": "rate(arbitragex_opportunities_processed_total[1m])",
            "legendFormat": "Opportunities/sec",
            "refId": "A"
          },
          {
            "expr": "rate(arbitragex_successful_submissions_total[1m])",
            "legendFormat": "Successful Submissions/sec",
            "refId": "B"
          },
          {
            "expr": "rate(arbitragex_failed_submissions_total[1m])",
            "legendFormat": "Failed Submissions/sec",
            "refId": "C"
          },
          {
            "expr": "arbitragex_ml_model_prediction_accuracy",
            "legendFormat": "ML Model Accuracy",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "custom": {
              "align": "auto",
              "cellOptions": {
                "type": "auto"
              },
              "inspect": false
            },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 80}
              ]
            }
          }
        },
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 5,
        "title": "📡 WebSocket & SSE Connection Health",
        "type": "stat",
        "targets": [
          {
            "expr": "arbitragex_websocket_connections_active",
            "legendFormat": "Active WebSocket Connections",
            "refId": "A"
          },
          {
            "expr": "rate(arbitragex_websocket_reconnects_total[1m])",
            "legendFormat": "Reconnects/min",
            "refId": "B"
          },
          {
            "expr": "arbitragex_sse_subscribers_count",
            "legendFormat": "SSE Subscribers",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "displayMode": "basic",
              "orientation": "horizontal"
            },
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 100},
                {"color": "red", "value": 1000}
              ]
            }
          }
        },
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 6,
        "title": "💰 MEV Performance & Profit Tracking",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(arbitragex_simulated_profit_total[1m])",
            "legendFormat": "Simulated Profit Rate (ETH/min)",
            "refId": "A"
          },
          {
            "expr": "rate(arbitragex_realized_profit_total[1m])",
            "legendFormat": "Realized Profit Rate (ETH/min)",
            "refId": "B"
          },
          {
            "expr": "arbitragex_bundle_inclusion_rate",
            "legendFormat": "Bundle Inclusion Rate (%)",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "opacity"
            },
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22}
      },
      {
        "id": 7,
        "title": "🚨 SLO Violations & Alert Status",
        "type": "alertlist",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 30},
        "options": {
          "showOptions": "current",
          "maxItems": 20,
          "sortOrder": 1,
          "dashboardAlerts": false,
          "alertName": "",
          "dashboardTitle": "",
          "folderId": null,
          "tags": ["arbitragex", "latency", "slo"]
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "5s",
    "schemaVersion": 38,
    "version": 1,
    "links": [
      {
        "asDropdown": false,
        "icon": "external link",
        "includeVars": false,
        "keepTime": false,
        "tags": ["arbitragex"],
        "targetBlank": true,
        "title": "ArbitrageX Dashboards",
        "tooltip": "Other ArbitrageX dashboards",
